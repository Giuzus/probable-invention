{
  "name": "giuzus-probable-invention",
  "private": false,
  "version": "0.1.4",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giuzus/probable-invention.git"
  },
  "author": "Giuzus",
